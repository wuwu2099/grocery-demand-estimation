# Virtual environments
# ======================================================
.env
.venv
env/
venv/

# Conda
.conda/
conda-meta/

# ======================================================
# Jupyter Notebook
# ======================================================
.ipynb_checkpoints/

# ======================================================
# VS Code
# ======================================================
.vscode/

# ======================================================
# Operating System
# ======================================================
.DS_Store
Thumbs.db
desktop.ini

# ======================================================
# Python cache
# ======================================================
.pytest_cache/
.mypy_cache/
.cache/

# ======================================================
# Logs
# ======================================================
*.log

# ======================================================
# Large data files
# ======================================================
data/raw/
data/external/
data/temp/

# Keep folder structure
!data/raw/.gitkeep
!data/external/.gitkeep
!data/temp/.gitkeep

# ======================================================
# Model outputs
# ======================================================
models/
*.pkl
*.joblib
*.h5
*.keras

